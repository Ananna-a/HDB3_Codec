IO_PORT "adc_data_a[4]" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "adc_data_a[3]" E16;
IO_PORT "adc_data_a[3]" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "adc_data_a[2]" D16;
IO_PORT "adc_data_a[2]" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "adc_data_a[1]" D17;
IO_PORT "adc_data_a[1]" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "adc_data_a[0]" C17;
IO_PORT "adc_data_a[0]" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;

// ADC通道A时钟输出
IO_LOC "adc_clk_out_a" F16;
IO_PORT "adc_clk_out_a" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;

// ADC通道B数据输入（8位，保留）
IO_LOC "adc_data_b[7]" F19;
IO_PORT "adc_data_b[7]" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
