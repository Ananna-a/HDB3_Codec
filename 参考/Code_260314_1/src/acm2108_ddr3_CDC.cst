// 引脚映射（物理引脚 -> 逻辑通道）:
//   P17 -> LA0 (LOGIC_OUT[0])
//   M17 -> LA1 (LOGIC_OUT[1])  // 替换N17（SSPI专用）
//   T18 -> LA2 (LOGIC_OUT[2])
//   R18 -> LA3 (LOGIC_OUT[3])
//   R14 -> LA4 (LOGIC_OUT[4])
//   P14 -> LA5 (LOGIC_OUT[5])
//   U18 -> LA6 (LOGIC_OUT[6])
//   U17 -> LA7 (LOGIC_OUT[7])
