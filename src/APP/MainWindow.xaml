<Window x:Class="HDB3_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HDB3_App.ViewModels"
        Title="HDB3 编解码器" Height="740" Width="1160"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="900">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部栏 -->
        <Border Grid.Row="0" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="HDB3" Foreground="#58A6FF" FontSize="18" FontWeight="Bold"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                    <TextBlock Text=" 编解码器" Foreground="#E6EDF3" FontSize="14"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <Border Background="#1F6FEB1A" CornerRadius="4" Padding="6,2" Margin="12,0,0,0">
                        <TextBlock Text="GW5AT-138B" Foreground="#58A6FF" FontSize="10"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding PortList}" SelectedItem="{Binding SelectedPort}"
                              Width="90" VerticalAlignment="Center" FontSize="12"
                              Style="{StaticResource PortCombo}"/>
                    <Button Content="{Binding ConnectButtonText}" Command="{Binding ConnectCmd}" Margin="8,0,0,0"
                            Style="{StaticResource BtnConnect}"/>

                    <Border Width="1" Background="#30363D" Margin="14,4"/>

                    <!-- 连接状态 -->
                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                            Background="#1B3A2D" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#3FB950" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="已连接" FontSize="11" Foreground="#3FB950" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="4" Padding="8,3"
                            Background="#3D1F28" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisInvert}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#F85149" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="未连接" FontSize="11" Foreground="#F85149" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="4" Padding="8,3"
                            Background="#2A2816" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="处理中..." FontSize="11" Foreground="#D29922" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 编码区 -->
            <Border Grid.Column="0" Background="#161B22" CornerRadius="10"
                    BorderBrush="#21262D" BorderThickness="1" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 标题 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="#1F6FEB" CornerRadius="3" Width="4" Margin="0,0,10,0"/>
                            <TextBlock Text="编码" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock Text="二进制 → HDB3" Foreground="#6E7681" FontSize="12"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- 输入 -->
                        <TextBlock Text="二进制序列" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding EncInput, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CodeInput}"/>

                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="0" Style="{StaticResource BtnChip}" Command="{Binding EncBit0Cmd}"/>
                            <Button Content="1" Style="{StaticResource BtnChip}" Command="{Binding EncBit1Cmd}"/>
                            <Button Content="随机" Style="{StaticResource BtnChip}"
                                    Command="{Binding EncRandCmd}" FontFamily="Microsoft YaHei UI"
                                    Foreground="#D29922"/>
                            <Button Content="清空" Style="{StaticResource BtnChip}"
                                    Command="{Binding EncClearCmd}" FontFamily="Microsoft YaHei UI"/>
                        </WrapPanel>

                        <Button Content="发送编码" Command="{Binding EncodeCmd}"
                                Style="{StaticResource BtnEncode}" Margin="0,12,0,14"/>

                        <!-- 期望结果 -->
                        <Border Background="#161B22" CornerRadius="6"
                                BorderBrush="#21262D" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="期望结果" Foreground="#6E7681" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding EncExpected}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SymChipExp}">
                                                <TextBlock Text="{Binding Value}" FontFamily="Consolas"
                                                           FontSize="12" Foreground="#8B949E"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- FPGA 返回 -->
                        <Border Background="#161B22" CornerRadius="6"
                                BorderBrush="#21262D" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="FPGA 返回" Foreground="#6E7681" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding EncActual}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="5,2" Margin="2" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                <Setter Property="Background" Value="#1B3A2D"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                <Setter Property="Background" Value="#3D1F28"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Value}" FontFamily="Consolas"
                                                           FontSize="12" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 状态 -->
                            <Border CornerRadius="6" Padding="10,8"
                                    Background="#161B22" BorderBrush="#21262D" BorderThickness="1">
                                <TextBlock Text="{Binding EncStatus}" FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EncStatus}" Value="✓ 全部正确">
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EncStatus}" Value="✗ 存在差异">
                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EncStatus}" Value="-">
                                                    <Setter Property="Foreground" Value="#484F58"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- 分隔 -->
                <GridSplitter Grid.Column="1" Width="12" Background="Transparent"
                              HorizontalAlignment="Stretch"/>

                <!-- 解码区 -->
                <Border Grid.Column="2" Background="#161B22" CornerRadius="10"
                    BorderBrush="#21262D" BorderThickness="1" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 标题 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="#238636" CornerRadius="3" Width="4" Margin="0,0,10,0"/>
                            <TextBlock Text="解码" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock Text="HDB3 → 二进制" Foreground="#6E7681" FontSize="12"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- 输入 -->
                        <TextBlock Text="HDB3 符号序列" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding DecInput, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CodeInput}"/>

                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="0"  Style="{StaticResource BtnChip}" Command="{Binding DecSymCmd}" CommandParameter="0"/>
                            <Button Content="+1" Style="{StaticResource BtnChip}" Command="{Binding DecSymCmd}" CommandParameter="+1"
                                    Foreground="#3FB950"/>
                            <Button Content="-1" Style="{StaticResource BtnChip}" Command="{Binding DecSymCmd}" CommandParameter="-1"
                                    Foreground="#F85149"/>
                            <Button Content="+V" Style="{StaticResource BtnChip}" Command="{Binding DecSymCmd}" CommandParameter="+V"
                                    Foreground="#3FB950"/>
                            <Button Content="-V" Style="{StaticResource BtnChip}" Command="{Binding DecSymCmd}" CommandParameter="-V"
                                    Foreground="#F85149"/>
                            <Button Content="+B" Style="{StaticResource BtnChip}" Command="{Binding DecSymCmd}" CommandParameter="+B"
                                    Foreground="#56D364"/>
                            <Button Content="-B" Style="{StaticResource BtnChip}" Command="{Binding DecSymCmd}" CommandParameter="-B"
                                    Foreground="#F85149"/>
                            <Button Content="退格" Style="{StaticResource BtnChip}"
                                    Command="{Binding DecBackCmd}" FontFamily="Microsoft YaHei UI"
                                    Foreground="#8B949E"/>
                            <Button Content="清空" Style="{StaticResource BtnChip}"
                                    Command="{Binding DecClearCmd}" FontFamily="Microsoft YaHei UI"
                                    Foreground="#8B949E"/>
                            <Button Content="随机" Style="{StaticResource BtnChip}"
                                    Command="{Binding DecRandCmd}" FontFamily="Microsoft YaHei UI"
                                    Foreground="#D29922"/>
                            <Button Content="导入" Style="{StaticResource BtnChip}"
                                    Command="{Binding DecImportCmd}" FontFamily="Microsoft YaHei UI"
                                    Foreground="#D29922"/>
                        </WrapPanel>

                        <Button Content="发送解码" Command="{Binding DecodeCmd}"
                                Style="{StaticResource BtnDecode}" Margin="0,12,0,14"/>

                        <!-- 期望结果 -->
                        <Border Background="#161B22" CornerRadius="6"
                                BorderBrush="#21262D" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="期望结果" Foreground="#6E7681" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding DecExpected}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SymChipExp}">
                                                <TextBlock Text="{Binding Value}" FontFamily="Consolas"
                                                           FontSize="12" Foreground="#8B949E"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- FPGA 返回 -->
                        <Border Background="#161B22" CornerRadius="6"
                                BorderBrush="#21262D" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="FPGA 返回" Foreground="#6E7681" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding DecActual}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="5,2" Margin="2" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                <Setter Property="Background" Value="#1B3A2D"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                <Setter Property="Background" Value="#3D1F28"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Value}" FontFamily="Consolas"
                                                           FontSize="12" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 状态 -->
                        <Border CornerRadius="6" Padding="10,8"
                                Background="#161B22" BorderBrush="#21262D" BorderThickness="1">
                            <TextBlock Text="{Binding DecStatus}" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DecStatus}" Value="✓ 全部正确">
                                                <Setter Property="Foreground" Value="#3FB950"/>
                                            </DataTrigger>
                                                <DataTrigger Binding="{Binding DecStatus}" Value="✗ 存在差异">
                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DecStatus}" Value="-">
                                                    <Setter Property="Foreground" Value="#484F58"/>
                                                </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 日志栏 -->
        <Border Grid.Row="2" Background="#0D1117" BorderBrush="#21262D" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 日志标题栏 -->
                <Border Grid.Row="0" Background="#161B22" Padding="14,6"
                        MouseLeftButtonDown="ToggleLogPanel" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▸" Foreground="#8B949E" FontSize="10"
                                   VerticalAlignment="Center" Name="LogArrow"/>
                        <TextBlock Text="输出日志" Foreground="#8B949E" FontSize="11"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                        <TextBlock Text="{Binding LogText, Converter={StaticResource LineCountConverter}}"
                                   Foreground="#484F58" FontSize="10"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <TextBox Grid.Row="1" Text="{Binding LogText, Mode=OneWay}"
                         Style="{StaticResource LogBox}" Name="LogBox"
                         Padding="14,8" Height="140"/>
            </Grid>
        </Border>
    </Grid>
</Window>
