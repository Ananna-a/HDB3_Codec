// =========================================================================
// I2C接口引脚 (OLED SSD1306)
// 引脚映射:
//   L18 -> IIC_SDA  (I2C数据线，双向)
//   M20 -> IIC_SCLK (I2C时钟线，输出)
// =========================================================================
IO_LOC "i2c_sda" M20;
IO_PORT "i2c_sda" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "i2c_scl" L18;
IO_PORT "i2c_scl" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;

// =========================================================================
// SPI接口引脚 (W25Q128 Flash / 通用SPI设备)
// 引脚映射:
//   B1  -> SPI_SCLK (SPI时钟，输出)
//   B2  -> SPI_CS   (片选，输出，低有效)
//   M17 -> SPI_MOSI (主出从入，输出)
//   A1  -> SPI_MISO (主入从出，输入)
// =========================================================================
IO_LOC "spi_sclk" B1;
IO_PORT "spi_sclk" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "spi_cs" B2;
IO_PORT "spi_cs" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "spi_mosi" M17;
IO_PORT "spi_mosi" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "spi_miso" A1;
IO_PORT "spi_miso" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

// DS18B20温度传感器接口 (1-Wire)
//   J1 -> DS18B20_DQ (单总线数据线，双向，需上拉)
IO_LOC "ds18b20_dq" J1;
IO_PORT "ds18b20_dq" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

// =========================================================================
// ADC接口引脚 (AD7928 双通道 8位ADC)
// ADC规格：最大采样率 35MSPS
// 系统配置：50MHz时钟，180°相位采样，基础降采样比4 → 12.5MSPS
// 引脚映射:
//   通道A (8位数据 + 时钟输出):
//     C18-C17 -> adc_data_a[7:0]
//     F16 -> adc_clk_out_a
//   通道B (8位数据 + 时钟输出，保留但当前未使用):
//     F19-E17 -> adc_data_b[7:0]
//     F20 -> adc_clk_out_b
// =========================================================================

// ADC通道A数据输入（8位）
IO_LOC "adc_data_a[7]" C18;
IO_PORT "adc_data_a[7]" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
