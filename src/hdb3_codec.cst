# =============================================================================
# hdb3_codec.cst - HDB3 codec pin constraints
# Board: ACX720 / GW5AT-138B (GW5AT-LV138PG484AC1/I0)
# =============================================================================

# ---- System clock 50 MHz ----
IO_LOC "clk_50m" Y18;
IO_PORT "clk_50m" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;

# ---- Reset, active low ----
IO_LOC "rst_n" F15;
IO_PORT "rst_n" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;

# ---- UART (CH340) ----
IO_LOC "uart_tx" M15;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "uart_rx" J21;
IO_PORT "uart_rx" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

# ---- DAC channel A ----
IO_LOC "DA0_Clk" A14;
IO_PORT "DA0_Clk" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA0_Data[7]" A13;
IO_PORT "DA0_Data[7]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA0_Data[6]" A16;
IO_PORT "DA0_Data[6]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA0_Data[5]" A15;
IO_PORT "DA0_Data[5]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA0_Data[4]" A19;
IO_PORT "DA0_Data[4]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA0_Data[3]" A18;
IO_PORT "DA0_Data[3]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA0_Data[2]" F14;
IO_PORT "DA0_Data[2]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA0_Data[1]" F13;
IO_PORT "DA0_Data[1]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA0_Data[0]" E14;
IO_PORT "DA0_Data[0]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;

# ---- DAC channel B ----
IO_LOC "DA1_Clk" E13;
IO_PORT "DA1_Clk" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA1_Data[7]" C13;
IO_PORT "DA1_Data[7]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA1_Data[6]" B13;
IO_PORT "DA1_Data[6]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA1_Data[5]" D14;
IO_PORT "DA1_Data[5]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA1_Data[4]" D15;
IO_PORT "DA1_Data[4]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA1_Data[3]" C14;
IO_PORT "DA1_Data[3]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA1_Data[2]" C15;
IO_PORT "DA1_Data[2]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "DA1_Data[1]" B15;
